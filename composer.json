{
	"name": "rkr/view",
	"description": "More secure and easy to use templating system for PHP 8.2+",
	"license": "MIT",
	"require": {
		"php": ">= 8.2"
	},
	"require-dev": {
		"phpstan/phpstan": "^2.1",
		"phpunit/phpunit": "^11.5",
		"rector/rector": "^2.3"
	},
	"autoload": {
		"psr-4": {
			"View\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"View\\": ["src/", "tests/"]
		}
	},
	"scripts": {
		"phpstan": "phpstan analyse -c phpstan.neon",
		"rector": "rector process",
		"rector:dry-run": "rector process --dry-run",
		"test": "phpunit -c phpunit.xml.dist"
	}
}
